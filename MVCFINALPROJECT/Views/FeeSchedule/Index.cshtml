@{
    ViewBag.Title = "Fee Schedules";
    ViewBag.ActiveMenu = "FeeSchedule";

    var schedules = ViewBag.FeeSchedules as System.Data.DataTable;
}

<div class="card">

    <!-- Card Header -->
    <div class="card-header">
        <div class="row">
            <div class="col-md-6">
                <i class="fa fa-money"></i> Fee Schedules
            </div>
            <div class="col-md-6 text-right no-print">

                <!-- Search input -->
                <input type="text"
                       id="searchFeeSchedule"
                       class="form-control input-sm"
                       placeholder="Search..."
                       style="width:180px;display:inline-block;
                              margin-right:5px" />

                <!-- Filter by year dropdown -->
                <select id="filterYear"
                        class="form-control input-sm"
                        style="width:130px;display:inline-block;
                               margin-right:5px">
                    <option value="">All Years</option>
                    @if (schedules != null)
                    {
                        // Build unique school year list for filter
                        var years = new System.Collections.Generic
                                        .HashSet<string>();
                        foreach (System.Data.DataRow r in schedules.Rows)
                        {
                            years.Add(r["SchoolYear"].ToString());
                        }
                        foreach (var yr in years)
                        {
                            <option value="@yr">@yr</option>
                        }
                    }
                </select>

                <!-- Add new fee schedule button -->
                <a href="@Url.Action("Create","FeeSchedule")"
                   class="btn btn-sm btn-primary">
                    <i class="fa fa-plus"></i> Add Fee Schedule
                </a>

            </div>
        </div>
    </div>

    <div class="card-body" style="padding:0">

        <!-- Success / Error messages -->
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success" style="margin:15px">
                <i class="fa fa-check-circle"></i> @TempData["Success"]
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger" style="margin:15px">
                <i class="fa fa-exclamation-circle"></i> @TempData["Error"]
            </div>
        }

        <!-- Fee Schedule Table -->
        <table class="table table-striped table-hover"
               id="feeScheduleTable">
            <thead>
                <tr>
                    <th>Course</th>
                    <th class="year-cell">School Year</th>
                    <th>Semester</th>
                    <th class="text-right">Tuition/Unit</th>
                    <th class="text-right">Reg Fee</th>
                    <th class="text-right">Misc Fee</th>
                    <th class="text-right">Lab Fee</th>
                    <th class="text-right">Total (21 units)</th>
                    <th class="no-print">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (schedules != null && schedules.Rows.Count > 0)
                {
                    foreach (System.Data.DataRow row in schedules.Rows)
                    {
                        // Compute sample total based on 21 units
                        decimal tuition = Convert.ToDecimal(row["TuitionFeePerUnit"]);
                        decimal regFee = Convert.ToDecimal(row["RegistrationFee"]);
                        decimal miscFee = Convert.ToDecimal(row["MiscellaneousFee"]);
                        decimal labFee = Convert.ToDecimal(row["LaboratoryFee"]);
                        decimal total = (tuition * 21) + regFee + miscFee + labFee;

                        <tr>
                            <td>
                                <strong>@row["CourseName"]</strong>
                            </td>
                            <td class="year-cell">@row["SchoolYear"]</td>
                            <td>@row["Semester"]</td>
                            <td class="text-right">
                                ₱@string.Format("{0:N2}", tuition)
                            </td>
                            <td class="text-right">
                                ₱@string.Format("{0:N2}", regFee)
                            </td>
                            <td class="text-right">
                                ₱@string.Format("{0:N2}", miscFee)
                            </td>
                            <td class="text-right">
                                ₱@string.Format("{0:N2}", labFee)
                            </td>
                            <td class="text-right" style="font-weight:bold;
                                                           color:#2c3e50">
                                ₱@string.Format("{0:N2}", total)
                            </td>
                            <td class="no-print">
                                <!-- Edit button -->
                                <a href="@Url.Action("Edit","FeeSchedule",
                                         new { id = row["FeeScheduleID"] })"
                                   class="btn btn-xs btn-warning"
                                   title="Edit">
                                    <i class="fa fa-edit"></i>
                                </a>
                                <!-- Delete button -->
                                @using (Html.BeginForm("Delete", "FeeSchedule",
                                        new { id = row["FeeScheduleID"] },
                                        FormMethod.Post))
                                {
                                    <button type="submit"
                                            class="btn btn-xs btn-danger
                                                   btn-delete"
                                            data-course="@row["CourseName"]"
                                            data-year="@row["SchoolYear"]"
                                            title="Delete">
                                        <i class="fa fa-trash"></i>
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="9" class="text-center text-muted">
                            <i class="fa fa-info-circle"></i>
                            No fee schedules found.
                            Click Add Fee Schedule to create one.
                        </td>
                    </tr>
                }
            </tbody>
        </table>

    </div>

    <!-- Card Footer -->
    <div class="card-body"
         style="padding:10px;border-top:1px solid #eee;
                font-size:12px;color:#888">
        @if (schedules != null)
        {
            <i class="fa fa-info-circle"></i>
            @: Total records: @schedules.Rows.Count fee schedule(s)
        }
    </div>

</div>

@section scripts {
    <script src="~/Scripts/myScript/feeSchedule.js"></script>
}