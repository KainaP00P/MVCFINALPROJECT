@{
    ViewBag.Title = "Fee Assessments";
    ViewBag.ActiveMenu = "Assessment";
}

<div class="card">

    <div class="card-header">
        <div class="row">
            <div class="col-md-6">
                <i class="fa fa-file-text"></i> Fee Assessments
            </div>
            <div class="col-md-6 text-right">
                <!-- Search -->
                <input type="text"
                       id="searchAssessment"
                       class="form-control input-sm no-print"
                       placeholder="Search student..."
                       style="width:200px;display:inline-block;margin-right:5px" />
                <!-- Add button -->
                <a href="@Url.Action("Create", "Assessment")"
                   class="btn btn-sm btn-primary no-print">
                    <i class="fa fa-plus"></i> New Assessment
                </a>
            </div>
        </div>
    </div>

    <div class="card-body" style="padding:0">

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success" style="margin:15px">
                <i class="fa fa-check-circle"></i> @TempData["Success"]
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger" style="margin:15px">
                <i class="fa fa-exclamation-circle"></i> @TempData["Error"]
            </div>
        }

        <table class="table table-striped table-hover"
               id="assessmentTable">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Student No.</th>
                    <th>Student Name</th>
                    <th>Course</th>
                    <th>School Year</th>
                    <th>Semester</th>
                    <th>Units</th>
                    <th>Total Assessment</th>
                    <th>Net Assessment</th>
                    <th>Assessed On</th>
                    <th class="no-print">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (ViewBag.Assessments != null)
                {
                    var assessments = ViewBag.Assessments
                                      as System.Data.DataTable;
                    int counter = 1;

                    if (assessments.Rows.Count == 0)
                    {
                        <tr>
                            <td colspan="11" class="text-center text-muted">
                                No assessments found.
                                Click New Assessment to begin.
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (System.Data.DataRow row in assessments.Rows)
                        {
                            decimal total = Convert.ToDecimal(
                                            row["TotalAssessment"]);
                            decimal net = Convert.ToDecimal(
                                            row["NetAssessment"]);
                            // Check if deductions were applied
                            bool hasDeduction = total != net;

                            <tr>
                                <td>@counter</td>
                                <td>@row["StudentNumber"]</td>
                                <td>
                                    <strong>@row["StudentName"]</strong>
                                </td>
                                <td>@row["CourseName"]</td>
                                <td>@row["SchoolYear"]</td>
                                <td>
                                    <span class="status-badge"
                                          style="background:#3498db;color:#fff">
                                        @row["Semester"] Sem
                                    </span>
                                </td>
                                <td class="text-center">
                                    @row["UnitsEnrolled"]
                                </td>
                                <td>
                                    ₱@string.Format("{0:N2}", total)
                                </td>
                                <td>
                                    <strong style="color:@(hasDeduction
                                               ? "#e74c3c" : "#2c3e50")">
                                        ₱@string.Format("{0:N2}", net)
                                    </strong>
                                    @if (hasDeduction)
                                    {
                                        <!-- Show deduction badge -->
                                        <span class="label label-warning"
                                              style="font-size:10px">
                                            w/ discount
                                        </span>
                                    }
                                </td>
                                <td>
                                    <small>
                                        @Convert.ToDateTime(row["AssessedAt"])
                                        .ToString("MMM dd, yyyy")
                                    </small>
                                </td>
                                <td class="no-print">
                                    <!-- View Details -->
                                    <a href="@Url.Action("Details",
                                             "Assessment",
                                             new { id = row["AssessmentID"] })"
                                       class="btn btn-xs btn-info">
                                        <i class="fa fa-eye"></i> View
                                    </a>
                                    <!-- Pay button -->
                                    <a href="@Url.Action("Create",
                                             "Payment",
                                             new { assessmentID =
                                                   row["AssessmentID"] })"
                                       class="btn btn-xs btn-success">
                                        <i class="fa fa-credit-card"></i> Pay
                                    </a>
                                </td>
                            </tr>
                            counter++;
                        }
                    }
                }
            </tbody>
        </table>

    </div>

    <div class="card-body"
         style="padding:10px;border-top:1px solid #eee;
                font-size:12px;color:#888">
        @if (ViewBag.Assessments != null)
        {
            var assessments = ViewBag.Assessments as System.Data.DataTable;
            <i class="fa fa-info-circle"></i>
            @: Total: @assessments.Rows.Count assessment(s)
        }
    </div>

</div>

@section scripts {
    <script src="~/Scripts/myScript/assessment.js"></script>
}