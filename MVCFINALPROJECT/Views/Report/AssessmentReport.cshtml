@{
    ViewBag.Title = "Assessment Report";
    ViewBag.ActiveMenu = "AssessmentReport";

    var assessments = ViewBag.AssessmentData as System.Data.DataTable;
    var courses = ViewBag.Courses as System.Data.DataTable;
}

<div class="card">

    <!-- Card Header -->
    <div class="card-header">
        <div class="row">
            <div class="col-md-5">
                <i class="fa fa-pie-chart"></i> Assessment Report
            </div>
            <div class="col-md-7 text-right no-print">
                <!-- Print button -->
                <button id="btnPrint" class="btn btn-sm btn-info">
                    <i class="fa fa-print"></i> Print
                </button>
                <!-- Export CSV button -->
                <button id="btnExportCSV" class="btn btn-sm btn-success">
                    <i class="fa fa-download"></i> Export CSV
                </button>
            </div>
        </div>
    </div>

    <!-- ── FILTER SECTION ── -->
    <div class="card-body filter-section no-print"
         style="background:#f8f9fa;border-bottom:1px solid #eee">

        @using (Html.BeginForm("AssessmentReport", "Report", FormMethod.Get))
        {
            <div class="row">

                <!-- School Year filter -->
                <div class="col-md-3">
                    <div class="form-group" style="margin:0">
                        <label style="font-size:12px">School Year</label>
                        <input type="text"
                               name="schoolYear"
                               class="form-control input-sm"
                               placeholder="e.g. 2024-2025"
                               value="@ViewBag.SchoolYear" />
                    </div>
                </div>

                <!-- Semester filter -->
                <div class="col-md-2">
                    <div class="form-group" style="margin:0">
                        <label style="font-size:12px">Semester</label>
                        <select name="semester"
                                id="filterSemester"
                                class="form-control input-sm">
                            <option value="">All Semesters</option>
                            <option value="1st"
                                    @(ViewBag.Semester == "1st" ? "selected" : "")>
                                1st Sem
                            </option>
                            <option value="2nd"
                                    @(ViewBag.Semester == "2nd" ? "selected" : "")>
                                2nd Sem
                            </option>
                            <option value="Summer"
                                    @(ViewBag.Semester == "Summer" ? "selected" : "")>
                                Summer
                            </option>
                        </select>
                    </div>
                </div>

                <!-- Course filter -->
                <div class="col-md-3">
                    <div class="form-group" style="margin:0">
                        <label style="font-size:12px">Course</label>
                        <select name="courseID"
                                class="form-control input-sm">
                            <option value="0">All Courses</option>
                            @if (courses != null)
                            {
                                foreach (System.Data.DataRow row in courses.Rows)
                                {
                                    <option value="@row["CourseID"]"
                                            @(ViewBag.CourseID.ToString() == row["CourseID"].ToString() ? "selected" : "")>
                                        @row["CourseCode"] - @row["CourseName"]
                                    </option>
                                }
                            }
                        </select>
                    </div>
                </div>

                <!-- Search and Clear buttons -->
                <div class="col-md-2">
                    <div class="form-group" style="margin:0">
                        <label style="font-size:12px">&nbsp;</label>
                        <div>
                            <button type="submit"
                                    class="btn btn-sm btn-primary">
                                <i class="fa fa-search"></i> Filter
                            </button>
                            <a href="@Url.Action("AssessmentReport","Report")"
                               class="btn btn-sm btn-default">
                                <i class="fa fa-refresh"></i> Clear
                            </a>
                        </div>
                    </div>
                </div>

            </div>

            <!-- Live search row -->
            <div class="row" style="margin-top:10px">
                <div class="col-md-4">
                    <input type="text"
                           id="searchAssessmentReport"
                           class="form-control input-sm"
                           placeholder="Live search in table..." />
                </div>
            </div>
        }

    </div>

    <!-- ── SUMMARY CARDS ── -->
    @if (assessments != null && assessments.Rows.Count > 0)
    {
        <div class="card-body no-print"
             style="background:#fff;border-bottom:1px solid #eee">
            <div class="row text-center">

                <div class="col-md-3">
                    <div style="font-size:12px;color:#888">
                        Total Students Assessed
                    </div>
                    <div style="font-size:24px;font-weight:bold;color:#3498db">
                        @assessments.Rows.Count
                    </div>
                </div>

                <div class="col-md-3">
                    <div style="font-size:12px;color:#888">
                        Gross Assessment
                    </div>
                    <div style="font-size:20px;font-weight:bold;color:#e67e22">
                        ₱@string.Format("{0:N2}", ViewBag.GrandTotalAssessment)
                    </div>
                </div>

                <div class="col-md-3">
                    <div style="font-size:12px;color:#888">
                        Total Deductions
                    </div>
                    <div style="font-size:20px;font-weight:bold;color:#e74c3c">
                        - ₱@string.Format("{0:N2}",
                       Convert.ToDecimal(ViewBag.GrandScholarship) +
                       Convert.ToDecimal(ViewBag.GrandDiscount))
                    </div>
                </div>

                <div class="col-md-3">
                    <div style="font-size:12px;color:#888">
                        Net Assessment Total
                    </div>
                    <div style="font-size:20px;font-weight:bold;color:#27ae60">
                        ₱@string.Format("{0:N2}", ViewBag.GrandNetAssessment)
                    </div>
                </div>

            </div>
        </div>
    }

    <!-- ── PRINT HEADER ── -->
    <div style="display:none" class="print-only">
        <div class="text-center" style="margin-bottom:15px">
            <h4 style="margin:0">Student Accounting System</h4>
            <h5 style="margin:5px 0">Assessment Report</h5>
            @if (!string.IsNullOrEmpty(ViewBag.SchoolYear as string))
            {
                <p style="margin:0;font-size:12px">
                    School Year: @ViewBag.SchoolYear
                    @if (!string.IsNullOrEmpty(ViewBag.Semester as string))
                    {
                        @: | Semester: @ViewBag.Semester
                    }
                </p>
            }
            <p style="margin:0;font-size:12px;color:#888">
                Printed: @DateTime.Now.ToString("MMMM dd, yyyy hh:mm tt")
            </p>
        </div>
        <hr />
    </div>

    <!-- ── ASSESSMENT TABLE ── -->
    <div class="card-body" style="padding:0">
        <table class="table table-striped table-bordered table-condensed"
               id="assessmentReportTable"
               style="font-size:12px">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Student No.</th>
                    <th>Student Name</th>
                    <th>Course</th>
                    <th>School Year</th>
                    <th class="col-semester">Semester</th>
                    <th class="text-right">Units</th>
                    <th class="text-right">Tuition</th>
                    <th class="text-right">Reg Fee</th>
                    <th class="text-right">Misc Fee</th>
                    <th class="text-right">Lab Fee</th>
                    <th class="text-right">Total</th>
                    <th class="text-right">Scholarship</th>
                    <th class="text-right">Discount</th>
                    <th class="text-right">Net Amount</th>
                    <th class="no-print">Action</th>
                </tr>
            </thead>
            <tbody>
                @if (assessments != null && assessments.Rows.Count > 0)
                {
                    int rowNum = 1;
                    foreach (System.Data.DataRow row in assessments.Rows)
                    {
                        <tr>
                            <td>@rowNum</td>
                            <td>@row["StudentNumber"]</td>
                            <td>
                                <strong>@row["StudentName"]</strong>
                            </td>
                            <td>@row["CourseName"]</td>
                            <td>@row["SchoolYear"]</td>
                            <td class="col-semester">@row["Semester"]</td>
                            <td class="text-right">@row["UnitsEnrolled"]</td>
                            <td class="text-right">
                                ₱@string.Format("{0:N2}", row["TuitionFee"])
                            </td>
                            <td class="text-right">
                                ₱@string.Format("{0:N2}", row["RegistrationFee"])
                            </td>
                            <td class="text-right">
                                ₱@string.Format("{0:N2}", row["MiscellaneousFee"])
                            </td>
                            <td class="text-right">
                                ₱@string.Format("{0:N2}", row["LaboratoryFee"])
                            </td>
                            <td class="text-right" style="font-weight:bold">
                                ₱@string.Format("{0:N2}", row["TotalAssessment"])
                            </td>
                            <td class="text-right" style="color:#e74c3c">
                                - ₱@string.Format("{0:N2}",
                                row["ScholarshipDeduction"])
                            </td>
                            <td class="text-right" style="color:#e74c3c">
                                - ₱@string.Format("{0:N2}",
                                row["DiscountDeduction"])
                            </td>
                            <td class="text-right"
                                style="font-weight:bold;color:#27ae60">
                                ₱@string.Format("{0:N2}", row["NetAssessment"])
                            </td>
                            <td class="no-print">
                                <a href="@Url.Action("Details","Assessment",
                                         new { id = row["AssessmentID"] })"
                                   class="btn btn-xs btn-info"
                                   title="View Assessment">
                                    <i class="fa fa-eye"></i>
                                </a>
                            </td>
                        </tr>
                        rowNum++;
                    }
                }
                else
                {
                    <tr>
                        <td colspan="16" class="text-center text-muted">
                            <i class="fa fa-info-circle"></i>
                            No assessment records found.
                            Use filters above to search.
                        </td>
                    </tr>
                }
            </tbody>

            <!-- ── GRAND TOTAL FOOTER ── -->
            @if (assessments != null && assessments.Rows.Count > 0)
            {
                <tfoot>
                    <tr style="background:#2c3e50;color:#fff;
                               font-weight:bold;font-size:12px">
                        <td colspan="7" class="text-right">
                            GRAND TOTAL:
                        </td>
                        <td class="text-right">
                            ₱@string.Format("{0:N2}",
                             assessments.Compute("SUM(TuitionFee)", ""))
                        </td>
                        <td class="text-right">
                            ₱@string.Format("{0:N2}",
                             assessments.Compute("SUM(RegistrationFee)", ""))
                        </td>
                        <td class="text-right">
                            ₱@string.Format("{0:N2}",
                             assessments.Compute("SUM(MiscellaneousFee)", ""))
                        </td>
                        <td class="text-right">
                            ₱@string.Format("{0:N2}",
                             assessments.Compute("SUM(LaboratoryFee)", ""))
                        </td>
                        <td class="text-right">
                            ₱@string.Format("{0:N2}",
                             ViewBag.GrandTotalAssessment)
                        </td>
                        <td class="text-right" style="color:#e74c3c">
                            - ₱@string.Format("{0:N2}", ViewBag.GrandScholarship)
                        </td>
                        <td class="text-right" style="color:#e74c3c">
                            - ₱@string.Format("{0:N2}", ViewBag.GrandDiscount)
                        </td>
                        <td class="text-right" style="color:#2ecc71">
                            ₱@string.Format("{0:N2}", ViewBag.GrandNetAssessment)
                        </td>
                        <td class="no-print"></td>
                    </tr>
                </tfoot>
            }

        </table>
    </div>

    <!-- Card Footer -->
    <div class="card-body no-print"
         style="padding:10px;border-top:1px solid #eee;
                font-size:12px;color:#888">
        @if (assessments != null)
        {
            <i class="fa fa-info-circle"></i>
            @: Total records: @assessments.Rows.Count assessment(s)
        }
    </div>

</div>

<style>
    @@media print {
        .print-only {
            display: block !important;
        }
    }
</style>

@section scripts {
    <script src="~/Scripts/myScript/report.js"></script>
}