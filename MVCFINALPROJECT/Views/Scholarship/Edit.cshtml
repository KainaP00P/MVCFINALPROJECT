@{
    ViewBag.Title = "Edit Scholarship";
    ViewBag.ActiveMenu = "Scholarship";

    // Get scholarship data passed from controller
    var scholarship = ViewBag.Scholarship as System.Data.DataRow;
}

<div class="card">

    <div class="card-header">
        <i class="fa fa-edit"></i> Edit Scholarship
        @if (scholarship != null)
        {
            <small class="text-muted" style="margin-left:10px">
                @scholarship["ScholarshipName"]
            </small>
        }
    </div>

    <div class="card-body">

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger">
                <i class="fa fa-exclamation-circle"></i> @ViewBag.Error
            </div>
        }

        @if (scholarship != null)
        {
            using (Html.BeginForm("Edit", "Scholarship",
                   new RouteValueDictionary { { "id", scholarship["ScholarshipID"] } },
                   FormMethod.Post,
                   new { id = "scholarshipForm" }))
            {
                <div class="row">

                    <!-- Scholarship Name -->
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>
                                Scholarship Name <span class="text-danger">*</span>
                            </label>
                            <input type="text"
                                   id="ScholarshipName"
                                   name="ScholarshipName"
                                   class="form-control"
                                   value="@scholarship["ScholarshipName"]" />
                            <span class="field-error" id="scholarshipNameError"></span>
                        </div>
                    </div>

                    <!-- Discount Percent -->
                    <div class="col-md-3">
                        <div class="form-group">
                            <label>
                                Discount Percent <span class="text-danger">*</span>
                            </label>
                            <div class="input-group">
                                <input type="number"
                                       id="DiscountPercent"
                                       name="DiscountPercent"
                                       class="form-control"
                                       value="@scholarship["DiscountPercent"]"
                                       min="1"
                                       max="100"
                                       step="0.01" />
                                <span class="input-group-addon">%</span>
                            </div>
                            <span class="field-error" id="discountPercentError"></span>
                            <!-- Live preview updated by scholarship.js -->
                            <small id="percentPreview"
                                   style="font-size:12px;color:green"></small>
                        </div>
                    </div>

                    <!-- Status -->
                    <div class="col-md-3">
                        <div class="form-group">
                            <label>Status</label>
                            <div style="margin-top:8px">
                                <input type="hidden" name="IsActive" value="false" />
                                <input type="checkbox"
                                       id="IsActive"
                                       name="IsActive"
                                       value="true"
                                       @(Convert.ToBoolean(scholarship["IsActive"]) ? "checked=checked" : "") />
                                <label for="IsActive" style="font-weight:normal">
                                    Active
                                </label>
                            </div>
                        </div>
                    </div>

                </div>

                <!-- Description -->
                <div class="row">
                    <div class="col-md-12">
                        <div class="form-group">
                            <label>
                                Description
                                <small class="text-muted">(optional)</small>
                            </label>
                            <textarea id="Description"
                                      name="Description"
                                      class="form-control"
                                      rows="3">@scholarship["Description"]</textarea>
                        </div>
                    </div>
                </div>

                <!-- Read-only info -->
                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group">
                            <label>Date Created</label>
                            <p class="form-control-static text-muted">
                                @Convert.ToDateTime(scholarship["CreatedAt"])
                                .ToString("MMM dd, yyyy hh:mm tt")
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Info box -->
                <div class="alert alert-info" style="font-size:12px">
                    <i class="fa fa-info-circle"></i>
                    <strong>Discount Percent Guide:</strong>
                    100% = Full Scholarship &nbsp;|&nbsp;
                    50% = Half Scholarship &nbsp;|&nbsp;
                    1-49% = Partial Scholarship
                </div>

                <!-- Buttons -->
                <div class="form-group">
                    <button type="submit" class="btn btn-primary">
                        <i class="fa fa-save"></i> Save Changes
                    </button>
                    <a href="@Url.Action("Index", "Scholarship")"
                       class="btn btn-default">
                        <i class="fa fa-arrow-left"></i> Back to List
                    </a>
                </div>
            }
        }
        else
        {
            <div class="alert alert-warning">
                <i class="fa fa-warning"></i> Scholarship not found.
            </div>
            <a href="@Url.Action("Index", "Scholarship")"
               class="btn btn-default">
                <i class="fa fa-arrow-left"></i> Back to List
            </a>
        }

    </div>
</div>

@section scripts {
    <script src="~/Scripts/myScript/scholarship.js"></script>
}