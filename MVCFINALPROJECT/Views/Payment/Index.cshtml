@{
    ViewBag.Title = "Payments";
    ViewBag.ActiveMenu = "Payment";
}

<div class="card">

    <!-- Card Header -->
    <div class="card-header">
        <div class="row">
            <div class="col-md-4">
                <i class="fa fa-credit-card"></i> Payment Records
            </div>
            <div class="col-md-8 text-right no-print">

                <!-- Search input -->
                <input type="text"
                       id="searchPayment"
                       class="form-control input-sm"
                       placeholder="Search payment..."
                       style="width:180px;display:inline-block;
                              margin-right:5px" />

                <!-- Filter by payment method -->
                <select id="filterMethod"
                        class="form-control input-sm"
                        style="width:130px;display:inline-block;
                               margin-right:5px">
                    <option value="">All Methods</option>
                    <option value="cash">Cash</option>
                    <option value="online">Online</option>
                    <option value="bank transfer">Bank Transfer</option>
                    <option value="check">Check</option>
                </select>

                <!-- Print button -->
                <button id="btnPrint" class="btn btn-sm btn-info">
                    <i class="fa fa-print"></i> Print
                </button>

            </div>
        </div>
    </div>

    <div class="card-body" style="padding:0">

        <!-- Success / Error messages -->
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success" style="margin:15px">
                <i class="fa fa-check-circle"></i> @TempData["Success"]
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger" style="margin:15px">
                <i class="fa fa-exclamation-circle"></i> @TempData["Error"]
            </div>
        }

        <!-- Payments Table -->
        <table class="table table-striped table-hover"
               id="paymentTable">
            <thead>
                <tr>
                    <th>OR Number</th>
                    <th>Student No.</th>
                    <th>Student Name</th>
                    <th>Term</th>
                    <th>Amount Paid</th>
                    <th>Payment Date</th>
                    <th class="method-cell">Method</th>
                    <th>Received By</th>
                    <th class="no-print">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (ViewBag.Payments != null)
                {
                    var payments = ViewBag.Payments as System.Data.DataTable;

                    if (payments.Rows.Count == 0)
                    {
                        <tr>
                            <td colspan="9" class="text-center text-muted">
                                <i class="fa fa-info-circle"></i>
                                No payment records found.
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (System.Data.DataRow row in payments.Rows)
                        {
                            <tr>
                                <td>
                                    <strong>@row["ORNumber"]</strong>
                                </td>
                                <td>@row["StudentNumber"]</td>
                                <td>@row["StudentName"]</td>
                                <td>
                                    <!-- Color code term name -->
                                    @{
                                        string termName = row["TermName"].ToString();
                                        string termColor = termName == "Prelim"
                                            ? "#3498db" : termName == "Midterm"
                                            ? "#e67e22" : termName == "Semi-Final"
                                            ? "#9b59b6" : "#27ae60";
                                    }
                                    <span style="color:@termColor;font-weight:bold">
                                        @termName
                                    </span>
                                </td>
                                <td style="color:#27ae60;font-weight:bold">
                                    ₱@string.Format("{0:N2}", row["AmountPaid"])
                                </td>
                                <td>
                                    @Convert.ToDateTime(row["PaymentDate"])
                                    .ToString("MMM dd, yyyy")
                                </td>
                                <td class="method-cell">
                                    @row["PaymentMethod"]
                                </td>
                                <td>@row["ReceivedByName"]</td>
                                <td class="no-print">
                                    <!-- View Details -->
                                    <a href="@Url.Action("Details","Payment",
                                             new { id = row["PaymentID"] })"
                                       class="btn btn-xs btn-info"
                                       title="View Details">
                                        <i class="fa fa-eye"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                }
            </tbody>
        </table>

    </div>

    <!-- Card Footer with record count -->
    <div class="card-body"
         style="padding:10px;border-top:1px solid #eee;
                font-size:12px;color:#888">
        @if (ViewBag.Payments != null)
        {
            var payments = ViewBag.Payments as System.Data.DataTable;

            // Compute grand total of all payments
            decimal grandTotal = 0;
            foreach (System.Data.DataRow row in payments.Rows)
            {
                grandTotal += Convert.ToDecimal(row["AmountPaid"]);
            }

            <i class="fa fa-info-circle"></i>
            @: Total records: @payments.Rows.Count payment(s) &nbsp;|&nbsp;
            <strong style="color:#27ae60">
                Grand Total: ₱@string.Format("{0:N2}", grandTotal)
            </strong>
        }
    </div>

</div>

@section scripts {
    <script src="~/Scripts/myScript/payment.js"></script>
}