@{
    ViewBag.Title = "Student Accounts";
    ViewBag.ActiveMenu = "Student";
}

<div class="card">

    <!-- Card Header with Search and Add Button -->
    <div class="card-header">
        <div class="row">
            <div class="col-md-6">
                <i class="fa fa-users"></i> Student Accounts
            </div>
            <div class="col-md-6 text-right">
                <!-- Search input -->
                <input type="text"
                       id="searchStudent"
                       class="form-control input-sm no-print"
                       placeholder="Search student..."
                       style="width:200px;display:inline-block;
                              margin-right:10px" />
                <!-- Add new student button (Admin only) -->
                <a href="@Url.Action("Create", "Student")"
                   class="btn btn-sm btn-primary no-print">
                    <i class="fa fa-plus"></i> Register Student
                </a>
            </div>
        </div>
    </div>

    <div class="card-body" style="padding:0">

        <!-- Success / Error messages -->
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success" style="margin:15px">
                <i class="fa fa-check-circle"></i> @TempData["Success"]
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger" style="margin:15px">
                <i class="fa fa-exclamation-circle"></i> @TempData["Error"]
            </div>
        }
        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger" style="margin:15px">
                <i class="fa fa-exclamation-circle"></i> @ViewBag.Error
            </div>
        }

        <!-- Student List Table -->
        <table class="table table-striped table-hover"
               id="studentTable">
            <thead>
                <tr>
                    <th>Student No.</th>
                    <th>Full Name</th>
                    <th>Course</th>
                    <th>Year</th>
                    <th>Semester</th>
                    <th>School Year</th>
                    <th>Status</th>
                    <th class="no-print">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (ViewBag.Students != null)
                {
                    var students = ViewBag.Students as System.Data.DataTable;

                    if (students.Rows.Count == 0)
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted">
                                <i class="fa fa-info-circle"></i>
                                No students found. Click Register Student to add one.
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (System.Data.DataRow row in students.Rows)
                        {
                            <tr>
                                <td>@row["StudentNumber"]</td>
                                <td>
                                    <strong>
                                        @row["LastName"], @row["FirstName"]
                                        @row["MiddleName"]
                                    </strong>
                                </td>
                                <td>@row["CourseName"]</td>
                                <td>Year @row["YearLevel"]</td>
                                <td>@row["Semester"]</td>
                                <td>@row["SchoolYear"]</td>
                                <td>
                                    <span class="status-badge badge-enrolled">
                                        @row["EnrollmentStatus"]
                                    </span>
                                </td>
                                <td class="no-print">
                                    <!-- View Details -->
                                    <a href="@Url.Action("Details","Student",
                                             new { id = row["StudentID"] })"
                                       class="btn btn-xs btn-info"
                                       title="View Details">
                                        <i class="fa fa-eye"></i>
                                    </a>
                                    <!-- Edit -->
                                    <a href="@Url.Action("Edit","Student",
                                             new { id = row["StudentID"] })"
                                       class="btn btn-xs btn-warning"
                                       title="Edit">
                                        <i class="fa fa-edit"></i>
                                    </a>
                                    <!-- Assessment -->
                                    <a href="@Url.Action("Create","Assessment")"
                                       class="btn btn-xs btn-success"
                                       title="Assess Fees">
                                        <i class="fa fa-file-text"></i>
                                    </a>
                                    <!-- Delete -->
                                    @using (Html.BeginForm("Delete", "Student",
                                            new { id = row["StudentID"] },
                                            FormMethod.Post))
                                    {
                                        <button type="submit"
                                                class="btn btn-xs btn-danger btn-delete"
                                                data-name="@row["FirstName"] @row["LastName"]"
                                                title="Delete">
                                            <i class="fa fa-trash"></i>
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    }
                }
            </tbody>
        </table>

    </div>

    <!-- Card Footer with record count -->
    <div class="card-body" style="padding:10px;border-top:1px solid #eee;
                                   font-size:12px;color:#888">
        @if (ViewBag.Students != null)
        {
            var students = ViewBag.Students as System.Data.DataTable;
            <i class="fa fa-info-circle"></i>
            @: Total records: @students.Rows.Count student(s)
        }
    </div>

</div>

@section scripts {
    <script src="~/Scripts/myScript/student.js"></script>
}