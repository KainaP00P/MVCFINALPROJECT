@{
    ViewBag.Title = "Register Student";
    ViewBag.ActiveMenu = "Student";
}

<div class="card">

    <!-- Card Header -->
    <div class="card-header">
        <i class="fa fa-user-plus"></i> Register New Student
    </div>

    <div class="card-body">

        <!-- Error message -->
        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger">
                <i class="fa fa-exclamation-circle"></i> @ViewBag.Error
            </div>
        }

        @using (Html.BeginForm("Create", "Student",
                FormMethod.Post, new { id = "studentForm" }))
        {
            <!-- ── SECTION 1: Login Account Info ── -->
            <div class="card" style="border:1px solid #ddd;margin-bottom:20px">
                <div class="card-header"
                     style="background:#3498db;color:#fff;font-size:13px">
                    <i class="fa fa-lock"></i> Login Account Information
                </div>
                <div class="card-body">
                    <div class="row">

                        <!-- Username -->
                        <div class="col-md-4">
                            <div class="form-group">
                                <label>Username <span class="text-danger">*</span></label>
                                <input type="text"
                                       id="Username"
                                       name="Username"
                                       class="form-control"
                                       placeholder="Enter username"
                                       autocomplete="new-password" />
                                <span class="field-error" id="usernameError"></span>
                            </div>
                        </div>

                        <!-- Password -->
                        <div class="col-md-4">
                            <div class="form-group">
                                <label>Password <span class="text-danger">*</span></label>
                                <input type="password"
                                       id="Password"
                                       name="Password"
                                       class="form-control"
                                       placeholder="Enter password"
                                       autocomplete="new-password" />
                                <span class="field-error" id="passwordError"></span>
                            </div>
                        </div>

                        <!-- Student Number (auto-generated) -->
                        <div class="col-md-4">
                            <div class="form-group">
                                <label>Student Number</label>
                                <input type="text"
                                       id="StudentNumber"
                                       name="StudentNumber"
                                       class="form-control"
                                       value="@ViewBag.StudentNumber"
                                       readonly />
                                <small class="text-muted">
                                    Auto-generated
                                </small>
                            </div>
                        </div>

                    </div>
                </div>
            </div>

            <!-- ── SECTION 2: Personal Information ── -->
            <div class="card" style="border:1px solid #ddd;margin-bottom:20px">
                <div class="card-header"
                     style="background:#27ae60;color:#fff;font-size:13px">
                    <i class="fa fa-user"></i> Personal Information
                </div>
                <div class="card-body">
                    <div class="row">

                        <!-- First Name -->
                        <div class="col-md-4">
                            <div class="form-group">
                                <label>First Name <span class="text-danger">*</span></label>
                                <input type="text"
                                       id="FirstName"
                                       name="FirstName"
                                       class="form-control"
                                       placeholder="Enter first name" />
                                <span class="field-error" id="firstNameError"></span>
                            </div>
                        </div>

                        <!-- Middle Name -->
                        <div class="col-md-4">
                            <div class="form-group">
                                <label>Middle Name</label>
                                <input type="text"
                                       id="MiddleName"
                                       name="MiddleName"
                                       class="form-control"
                                       placeholder="Enter middle name (optional)" />
                            </div>
                        </div>

                        <!-- Last Name -->
                        <div class="col-md-4">
                            <div class="form-group">
                                <label>Last Name <span class="text-danger">*</span></label>
                                <input type="text"
                                       id="LastName"
                                       name="LastName"
                                       class="form-control"
                                       placeholder="Enter last name" />
                                <span class="field-error" id="lastNameError"></span>
                            </div>
                        </div>

                    </div>

                    <div class="row">

                        <!-- Gender -->
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>Gender <span class="text-danger">*</span></label>
                                <select id="Gender" name="Gender"
                                        class="form-control">
                                    <option value="">-- Select --</option>
                                    <option value="Male">Male</option>
                                    <option value="Female">Female</option>
                                </select>
                                <span class="field-error" id="genderError"></span>
                            </div>
                        </div>

                        <!-- Birth Date -->
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>Birth Date <span class="text-danger">*</span></label>
                                <input type="date"
                                       id="BirthDate"
                                       name="BirthDate"
                                       class="form-control" />
                                <span class="field-error" id="birthDateError"></span>
                            </div>
                        </div>

                        <!-- Contact Number -->
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>Contact Number <span class="text-danger">*</span></label>
                                <input type="text"
                                       id="ContactNumber"
                                       name="ContactNumber"
                                       class="form-control"
                                       placeholder="09XXXXXXXXX"
                                       maxlength="11" />
                                <span class="field-error" id="contactError"></span>
                            </div>
                        </div>

                        <!-- Email -->
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>Email <span class="text-danger">*</span></label>
                                <input type="email"
                                       id="Email"
                                       name="Email"
                                       class="form-control"
                                       placeholder="email@example.com" />
                                <span class="field-error" id="emailError"></span>
                            </div>
                        </div>

                    </div>

                    <!-- Address -->
                    <div class="row">
                        <div class="col-md-12">
                            <div class="form-group">
                                <label>Address <span class="text-danger">*</span></label>
                                <input type="text"
                                       id="Address"
                                       name="Address"
                                       class="form-control"
                                       placeholder="Enter complete address" />
                                <span class="field-error" id="addressError"></span>
                            </div>
                        </div>
                    </div>

                </div>
            </div>

            <!-- ── SECTION 3: Academic Information ── -->
            <div class="card" style="border:1px solid #ddd;margin-bottom:20px">
                <div class="card-header"
                     style="background:#e67e22;color:#fff;font-size:13px">
                    <i class="fa fa-book"></i> Academic Information
                </div>
                <div class="card-body">
                    <div class="row">

                        <!-- Course -->
                        <div class="col-md-4">
                            <div class="form-group">
                                <label>Course <span class="text-danger">*</span></label>
                                <select id="CourseID" name="CourseID"
                                        class="form-control">
                                    <option value="">-- Select Course --</option>
                                    @if (ViewBag.Courses != null)
                                    {
                                        var courses = ViewBag.Courses
                                                      as System.Data.DataTable;
                                        foreach (System.Data.DataRow row in courses.Rows)
                                        {
                                            <option value="@row["CourseID"]">
                                                @row["CourseCode"] -
                                                @row["CourseName"]
                                            </option>
                                        }
                                    }
                                </select>
                                <span class="field-error" id="courseError"></span>
                            </div>
                        </div>

                        <!-- Year Level -->
                        <div class="col-md-2">
                            <div class="form-group">
                                <label>Year Level <span class="text-danger">*</span></label>
                                <select id="YearLevel" name="YearLevel"
                                        class="form-control">
                                    <option value="">--</option>
                                    <option value="1">1st Year</option>
                                    <option value="2">2nd Year</option>
                                    <option value="3">3rd Year</option>
                                    <option value="4">4th Year</option>
                                </select>
                                <span class="field-error" id="yearLevelError"></span>
                            </div>
                        </div>

                        <!-- Semester -->
                        <div class="col-md-2">
                            <div class="form-group">
                                <label>Semester <span class="text-danger">*</span></label>
                                <select id="Semester" name="Semester"
                                        class="form-control">
                                    <option value="">--</option>
                                    <option value="1st">1st Sem</option>
                                    <option value="2nd">2nd Sem</option>
                                    <option value="Summer">Summer</option>
                                </select>
                                <span class="field-error" id="semesterError"></span>
                            </div>
                        </div>

                        <!-- School Year -->
                        <div class="col-md-4">
                            <div class="form-group">
                                <label>School Year <span class="text-danger">*</span></label>
                                <input type="text"
                                       id="SchoolYear"
                                       name="SchoolYear"
                                       class="form-control"
                                       placeholder="e.g. 2024-2025"
                                       maxlength="9" />
                                <span class="field-error" id="schoolYearError"></span>
                            </div>
                        </div>

                    </div>
                </div>
            </div>

            <!-- ── BUTTONS ── -->
            <div class="form-group">
                <button type="submit" class="btn btn-primary">
                    <i class="fa fa-save"></i> Register Student
                </button>
                <a href="@Url.Action("Index", "Student")"
                   class="btn btn-default">
                    <i class="fa fa-arrow-left"></i> Back to List
                </a>
            </div>

        }

    </div>
</div>

@section scripts {
    <script src="~/Scripts/myScript/student.js"></script>
}