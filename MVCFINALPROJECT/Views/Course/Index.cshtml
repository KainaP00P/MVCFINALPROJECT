@{
    ViewBag.Title = "Course Management";
    ViewBag.ActiveMenu = "Course";
}

<div class="card">

    <div class="card-header">
        <div class="row">
            <div class="col-md-6">
                <i class="fa fa-book"></i> Course Management
            </div>
            <div class="col-md-6 text-right">
                <!-- Status filter dropdown -->
                <select id="filterStatus"
                        class="form-control input-sm no-print"
                        style="width:120px;display:inline-block;margin-right:5px">
                    <option value="">All Status</option>
                    <option value="active">Active</option>
                    <option value="inactive">Inactive</option>
                </select>
                <!-- Search input -->
                <input type="text"
                       id="searchCourse"
                       class="form-control input-sm no-print"
                       placeholder="Search course..."
                       style="width:180px;display:inline-block;margin-right:5px" />
                <!-- Add button -->
                <a href="@Url.Action("Create", "Course")"
                   class="btn btn-sm btn-primary no-print">
                    <i class="fa fa-plus"></i> Add Course
                </a>
            </div>
        </div>
    </div>

    <div class="card-body" style="padding:0">

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success" style="margin:15px">
                <i class="fa fa-check-circle"></i> @TempData["Success"]
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger" style="margin:15px">
                <i class="fa fa-exclamation-circle"></i> @TempData["Error"]
            </div>
        }

        <table class="table table-striped table-hover" id="courseTable">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Course Code</th>
                    <th>Course Name</th>
                    <th>Department</th>
                    <th>Status</th>
                    <th>Created</th>
                    <th class="no-print">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (ViewBag.Courses != null)
                {
                    var courses = ViewBag.Courses as System.Data.DataTable;
                    int counter = 1;

                    if (courses.Rows.Count == 0)
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted">
                                No courses found. Click Add Course to begin.
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (System.Data.DataRow row in courses.Rows)
                        {
                            bool isActive = Convert.ToBoolean(row["IsActive"]);
                            <tr>
                                <td>@counter</td>
                                <td><strong>@row["CourseCode"]</strong></td>
                                <td>@row["CourseName"]</td>
                                <td>@row["Department"]</td>
                                <td>
                                    <span class="status-badge @(isActive
                                          ? "badge-active" : "badge-inactive")">
                                        <!-- Used by JS filter -->
                                        <span class="status-badge">
                                            @(isActive ? "Active" : "Inactive")
                                        </span>
                                    </span>
                                </td>
                                <td>
                                    @Convert.ToDateTime(row["CreatedAt"])
                                    .ToString("MMM dd, yyyy")
                                </td>
                                <td class="no-print">
                                    <!-- Edit -->
                                    <a href="@Url.Action("Edit","Course",
                                             new { id = row["CourseID"] })"
                                       class="btn btn-xs btn-warning">
                                        <i class="fa fa-edit"></i>
                                    </a>
                                    <!-- Toggle Active/Inactive -->
                                    @using (Html.BeginForm("ToggleStatus", "Course",
                                            new { id = row["CourseID"] },
                                            FormMethod.Post))
                                    {
                                        <button type="submit"
                                                class="btn btn-xs @(isActive
                                                       ? "btn-default" : "btn-success")
                                                       btn-toggle"
                                                data-name="@row["CourseName"]"
                                                data-status="@(isActive ? "1" : "0")"
                                                title="@(isActive
                                                       ? "Deactivate" : "Activate")">
                                            <i class="fa @(isActive
                                               ? "fa-toggle-on" : "fa-toggle-off")">
                                            </i>
                                        </button>
                                    }
                                    <!-- Delete -->
                                    @using (Html.BeginForm("Delete", "Course",
                                            new { id = row["CourseID"] },
                                            FormMethod.Post))
                                    {
                                        <button type="submit"
                                                class="btn btn-xs btn-danger btn-delete"
                                                data-name="@row["CourseName"]">
                                            <i class="fa fa-trash"></i>
                                        </button>
                                    }
                                </td>
                            </tr>
                            counter++;
                        }
                    }
                }
            </tbody>
        </table>

    </div>

    <div class="card-body"
         style="padding:10px;border-top:1px solid #eee;font-size:12px;color:#888">
        @if (ViewBag.Courses != null)
        {
            var courses = ViewBag.Courses as System.Data.DataTable;
            <i class="fa fa-info-circle"></i>
            @: Total: @courses.Rows.Count course(s)
        }
    </div>

</div>

@section scripts {
    <script src="~/Scripts/myScript/course.js"></script>
}